# Copy file này thành .env và điền giá trị thật vào.
# File .env đã được .gitignore - không commit lên repo.

# API key Alibaba DashScope (Qwen).
DASHSCOPE_API_KEY=sk-your-key-here

# Endpoint OpenAI-compatible của DashScope.
DASHSCOPE_BASE_URL=your-base-url

# Model dùng cho OCR captcha. Khuyến nghị qwen-vl-max-latest (mạnh nhất),
# qwen-vl-plus (rẻ hơn) hoặc qwen-vl-ocr-latest (chuyên OCR, có thể tốt hơn cho captcha).
DASHSCOPE_MODEL=your-model
